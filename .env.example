# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# Required when using the CORS proxy:
# Full URL of the SPARQL endpoint the proxy should forward requests to.
SPARQL_ENDPOINT=https://your-endpoint.example.com/sparql

# Optional: restrict CORS to your frontend origin.
# Defaults to * (all origins) which is fine for local development.
ALLOWED_ORIGIN=http://localhost:5173
